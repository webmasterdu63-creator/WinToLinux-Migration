#cloud-config

hostname: wintolinux
manage_etc_hosts: true

locale: fr_FR.UTF-8
timezone: Europe/Paris

keyboard:
  layout: fr
  variant: oss

# Création utilisateur
users:
  - name: wintolinux
    gecos: "WinToLinux User"
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: sudo
    shell: /bin/bash
    lock_passwd: false
    passwd: "$6$rounds=4096$wintolinux$Q2p7u5lZg3qk1y8xJq8u8W8gZ8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8F8u8"

package_update: true
package_upgrade: true

packages:
  - git
  - curl
  - wget
  - dialog
  - xterm
  - whiptail

runcmd:
  # Clonage du projet WintoLinux
  - git clone https://github.com/webmasterdu63-creator/WinToLinux-Migration /opt/wintolinux

  # Permissions
  - chmod +x /opt/wintolinux/scripts/*.sh

  # Lancement automatique de l’assistant au premier boot
  - echo "[Desktop Entry]
    Name=WinToLinux Migration
    Exec=/opt/wintolinux/scripts/wintolinux.sh
    Type=Application
    Terminal=true" > /home/wintolinux/.config/autostart/wintolinux.desktop

  - chown -R wintolinux:wintolinux /home/wintolinux/.config

final_message: "WinToLinux est prêt !"

